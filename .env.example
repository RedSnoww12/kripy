# Firebase Web SDK config — get values from Firebase Console → Project Settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Fit (sync des pas) — OAuth Client ID Web depuis Google Cloud Console
# (APIs & Services → Credentials, activer l'API Fitness). Optionnel.
VITE_GOOGLE_FIT_CLIENT_ID=
